{
  "name": "finance-mosaix-electron",
  "version": "0.2.0",
  "private": true,
  "description": "Electron wrapper for the Finance Mosaix Streamlit dashboard.",
  "author": "Developer-Simon",
  "repository": {
    "type": "git",
    "url": "https://github.com/Developer-Simon/finance-mosaix.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-runtime": "node -e \"require('child_process').spawnSync('python', ['build_python_runtime.py'], {stdio:'inherit'})\"",
    "generate-icon": "node generate-icon.js",
    "sync-version": "node sync_version.js",
    "dist": "npm run build-runtime && npm run sync-version && electron-builder --publish never"
  },
  "devDependencies": {
    "electron": "^26.0.0",
    "electron-builder": "^24.0.0",
    "png-to-ico": "^2.0.0",
    "sharp": "^0.32.0"
  },
  "build": {
    "appId": "com.finance.mosaix.dashboard",
    "productName": "Finance Mosaix Dashboard",
    "icon": "../docs/img/favicon.ico",
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../dashboard",
        "to": "dashboard",
        "filter": [
          "**/*",
          "!settings.json",
          "!**/__pycache__/**",
          "!**/*.py[cod]"
        ]
      },
      {
        "from": "../src",
        "to": "src",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.py[cod]"
        ]
      },
      {
        "from": "../pyproject.toml",
        "to": "pyproject.toml"
      },
      {
        "from": "../start_dashboard.py",
        "to": "start_dashboard.py"
      },
      {
        "from": "../electron/VERSION",
        "to": "VERSION"
      },
      {
        "from": "python-runtime",
        "to": "python-runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "build"
    },
    "publish": null,
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}
